-- DataBase Multi Image Loader - Ready
-- Uses your UI library + DrawingHandler/Layers.
-- Current sources:
-- IceCream:    https://raw.githubusercontent.com/tbest8403-dotcom/DataBase/refs/heads/main/Icecream
-- Gojo:        https://raw.githubusercontent.com/tbest8403-dotcom/DataBase/refs/heads/main/Gojo
-- Bunny:       https://raw.githubusercontent.com/tbest8403-dotcom/DataBase/refs/heads/main/Bunny
-- KissScene:   https://raw.githubusercontent.com/tbest8403-dotcom/DataBase/refs/heads/main/KissScene
-- CreepySmile: https://raw.githubusercontent.com/tbest8403-dotcom/DataBase/refs/heads/main/CreepySmile
-- Obito:       https://raw.githubusercontent.com/tbest8403-dotcom/DataBase/refs/heads/main/Obito
-- FunnyMonkey: https://raw.githubusercontent.com/tbest8403-dotcom/DataBase/refs/heads/main/FunnyMonkey

-- Features:
-- - Pick image from dropdown
-- - Pick quality: 64 / 96 / 128
-- - Preview image
-- - Draw to canvas
-- - Clear canvas
-- - Angle: 0 / 90 / 180 / 270

local UI_URL = "https://raw.githubusercontent.com/tbest8403-dotcom/29292929_8282Uilib/refs/heads/main/alib"

local IMAGE_SOURCES = {
    ["IceCream"] = "https://raw.githubusercontent.com/tbest8403-dotcom/DataBase/refs/heads/main/Icecream",
    ["Gojo"] = "https://raw.githubusercontent.com/tbest8403-dotcom/DataBase/refs/heads/main/Gojo",
    ["Bunny"] = "https://raw.githubusercontent.com/tbest8403-dotcom/DataBase/refs/heads/main/Bunny",
    ["KissScene"] = "https://raw.githubusercontent.com/tbest8403-dotcom/DataBase/refs/heads/main/KissScene",
    ["CreepySmile"] = "https://raw.githubusercontent.com/tbest8403-dotcom/DataBase/refs/heads/main/CreepySmile",
    ["Obito"] = "https://raw.githubusercontent.com/tbest8403-dotcom/DataBase/refs/heads/main/Obito",
    ["FunnyMonkey"] = "https://raw.githubusercontent.com/tbest8403-dotcom/DataBase/refs/heads/main/FunnyMonkey",
}

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
local PlayerScripts = LocalPlayer:WaitForChild("PlayerScripts")

local Library = loadstring(game:HttpGet(UI_URL))()

local Libraries = PlayerScripts:WaitForChild("Libraries")
local DrawingHandlerModule = Libraries:WaitForChild("DrawingHandler")
local ResFolder = Libraries:WaitForChild("ResFolder")

pcall(function()
    require(DrawingHandlerModule)
end)

local Layers = require(DrawingHandlerModule:WaitForChild("Layers"))

local History = nil
pcall(function()
    local historyModule = Libraries:FindFirstChild("History")
    if historyModule then
        History = require(historyModule)
    end
end)

repeat task.wait() until ResFolder:GetAttribute("Loaded") == true

local CanvasResolution = ResFolder:GetAttribute("Resolution") or 512
ResFolder:GetAttributeChangedSignal("Resolution"):Connect(function()
    CanvasResolution = ResFolder:GetAttribute("Resolution") or CanvasResolution
end)

local SelectedImage = "FunnyMonkey"
local CurrentQuality = "128"
local CurrentAngle = 0
local CurrentPack = nil
local Busy = false

local PreviewGui = nil
local PreviewFrame = nil
local PreviewHolder = nil
local PreviewCells = {}

local function notify(title, content, typeName, duration)
    pcall(function()
        Library:Notify({
            Title = title,
            Content = content,
            Type = typeName or "info",
            Duration = duration or 3,
        })
    end)
end

local function destroyPreview()
    PreviewCells = {}
    if PreviewGui then
        PreviewGui:Destroy()
        PreviewGui = nil
        PreviewFrame = nil
        PreviewHolder = nil
    end
end

local function loadSelectedPack(force)
    if CurrentPack and not force then
        return CurrentPack
    end

    local url = IMAGE_SOURCES[SelectedImage]
    if not url then
        notify("Data Error", "No URL found for " .. tostring(SelectedImage), "error", 4)
        return nil
    end

    notify("Loading", "Loading " .. tostring(SelectedImage) .. " data...", "info", 2)

    local ok, result = pcall(function()
        return loadstring(game:HttpGet(url))()
    end)

    if not ok or type(result) ~= "table" or type(result.qualities) ~= "table" then
        notify("Load Error", "Failed to load " .. tostring(SelectedImage), "error", 5)
        warn("[Multi Image Loader] Failed URL:", url, result)
        return nil
    end

    CurrentPack = result
    notify("Loaded", "Loaded " .. tostring(result.displayName or SelectedImage), "success", 2)
    return CurrentPack
end

local function getActiveData()
    local pack = loadSelectedPack(false)
    if not pack then
        return nil
    end

    return pack.qualities[CurrentQuality]
        or pack.qualities["128"]
        or pack.qualities["96"]
        or pack.qualities["64"]
end

local function getPreviewCellSize(size)
    if UserInputService.TouchEnabled then
        if size >= 128 then
            return 2
        elseif size >= 96 then
            return 3
        else
            return 4
        end
    else
        if size >= 128 then
            return 3
        elseif size >= 96 then
            return 4
        else
            return 5
        end
    end
end

local function addUndo()
    if History and History.AddToUndoHistory then
        pcall(function()
            History.AddToUndoHistory()
        end)
    end
end

local function getCanvas()
    local ok, canvas = pcall(function()
        return Layers:GetCurrentCanvas(true)
    end)

    if not ok or not canvas then
        notify("Canvas", "No active drawing layer found.", "error", 4)
        return nil
    end

    canvas.Alpha = 1
    canvas.AlphaBlendingMode = 1
    return canvas
end

local function renderCanvas(canvas)
    if not canvas then
        return
    end

    pcall(function()
        canvas:Render()
    end)

    pcall(function()
        local temp = Layers:GetTemporaryCanvas()
        if temp then
            temp:Clear()
            temp:Render()
        end
    end)
end

local function hexToColor3(hex)
    local r = bit32.rshift(hex, 16)
    local g = bit32.band(bit32.rshift(hex, 8), 255)
    local b = bit32.band(hex, 255)
    return Color3.fromRGB(r, g, b)
end

local function transformXY(x, y, w, h)
    if CurrentAngle == 90 then
        return h - y + 1, x
    elseif CurrentAngle == 180 then
        return w - x + 1, h - y + 1
    elseif CurrentAngle == 270 then
        return y, w - x + 1
    end

    return x, y
end

local function getPixelHex(data, x, y)
    local tx, ty = transformXY(x, y, data.w, data.h)
    return data.pixels[(ty - 1) * data.w + tx]
end

local function scaleCanvas(v)
    return v / 128 * CanvasResolution
end

local function canvasVec(x, y)
    return Vector2.new(scaleCanvas(x), scaleCanvas(y))
end

local function drawBlock(canvas, x1, y1, x2, y2, color)
    local startY = math.floor(y1)
    local endY = math.ceil(y2)
    local thickness = math.max(1, math.floor(scaleCanvas(1)))

    for yy = startY, endY do
        canvas:DrawLine(canvasVec(x1, yy), canvasVec(x2, yy), color, thickness, true)
    end
end

local function clearCanvas()
    if Busy then
        notify("Busy", "Already working.", "warning", 2)
        return
    end

    Busy = true

    local canvas = getCanvas()
    if canvas then
        addUndo()

        if canvas.SetClearRGBA then
            canvas:SetClearRGBA(1, 1, 1, 1)
        end

        canvas:Clear()
        renderCanvas(canvas)
        notify("Canvas", "Cleared current layer.", "success", 2)
    end

    Busy = false
end

local function drawImageToCanvas()
    if Busy then
        notify("Busy", "Already drawing.", "warning", 2)
        return
    end

    Busy = true

    local data = getActiveData()
    local pack = CurrentPack

    if not data or not pack then
        Busy = false
        notify("Data Error", "No image data loaded.", "error", 4)
        return
    end

    local canvas = getCanvas()
    if not canvas then
        Busy = false
        return
    end

    addUndo()

    if canvas.SetClearRGBA then
        canvas:SetClearRGBA(1, 1, 1, 1)
    end

    canvas:Clear()

    local logicalW = 128
    local logicalH = 128
    local blockW = logicalW / data.w
    local blockH = logicalH / data.h

    for y = 1, data.h do
        for x = 1, data.w do
            local color = hexToColor3(getPixelHex(data, x, y))

            local x1 = (x - 1) * blockW + 1
            local y1 = (y - 1) * blockH + 1
            local x2 = x * blockW + 1
            local y2 = y * blockH + 1

            drawBlock(canvas, x1, y1, x2, y2, color)
        end

        if y % math.max(4, math.floor(data.h / 20)) == 0 then
            task.wait()
        end
    end

    renderCanvas(canvas)

    notify(
        "Draw Complete",
        tostring(pack.displayName or SelectedImage) .. " Q" .. tostring(CurrentQuality) .. " was drawn.",
        "success",
        4
    )

    Busy = false
end

local function makeDraggable(frame, handle)
    local dragging = false
    local dragStart = nil
    local startPos = nil

    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)

    handle.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if not dragging then
            return
        end

        if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then
            return
        end

        local delta = input.Position - dragStart

        frame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end)
end

local function refreshPreview()
    if not PreviewHolder then
        return
    end

    local data = getActiveData()
    if not data then
        return
    end

    for y = 1, data.h do
        for x = 1, data.w do
            local i = (y - 1) * data.w + x
            local cell = PreviewCells[i]

            if cell then
                cell.BackgroundColor3 = hexToColor3(getPixelHex(data, x, y))
            end
        end
    end
end

local function createPreviewGui()
    destroyPreview()

    local data = getActiveData()
    local pack = CurrentPack

    if not data or not pack then
        notify("Preview Error", "No data loaded.", "error", 4)
        return
    end

    local previewCell = getPreviewCellSize(data.w)
    local previewSize = previewCell * data.w

    PreviewGui = Instance.new("ScreenGui")
    PreviewGui.Name = "DataBaseImagePreviewGui"
    PreviewGui.ResetOnSpawn = false
    PreviewGui.IgnoreGuiInset = true
    PreviewGui.Parent = PlayerGui

    PreviewFrame = Instance.new("Frame")
    PreviewFrame.Size = UDim2.fromOffset(previewSize + 22, previewSize + 64)
    PreviewFrame.Position = UDim2.new(
        0.5,
        -math.floor((previewSize + 22) / 2),
        0.5,
        -math.floor((previewSize + 64) / 2)
    )
    PreviewFrame.BackgroundColor3 = Color3.fromRGB(22, 22, 28)
    PreviewFrame.BorderSizePixel = 0
    PreviewFrame.Parent = PreviewGui

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 12)
    corner.Parent = PreviewFrame

    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(70, 70, 86)
    stroke.Thickness = 1
    stroke.Parent = PreviewFrame

    local top = Instance.new("Frame")
    top.Size = UDim2.new(1, 0, 0, 34)
    top.BackgroundColor3 = Color3.fromRGB(30, 30, 38)
    top.BorderSizePixel = 0
    top.Parent = PreviewFrame

    local topCorner = Instance.new("UICorner")
    topCorner.CornerRadius = UDim.new(0, 12)
    topCorner.Parent = top

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new(1, 0, 0, 12)
    fill.Position = UDim2.new(0, 0, 1, -12)
    fill.BackgroundColor3 = Color3.fromRGB(30, 30, 38)
    fill.BorderSizePixel = 0
    fill.Parent = top

    local title = Instance.new("TextLabel")
    title.BackgroundTransparency = 1
    title.Size = UDim2.new(1, -42, 1, 0)
    title.Position = UDim2.fromOffset(10, 0)
    title.Text = tostring(pack.displayName or SelectedImage) .. " Preview Q" .. tostring(CurrentQuality)
    title.TextColor3 = Color3.fromRGB(255, 255, 255)
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.Font = Enum.Font.GothamBold
    title.TextSize = 13
    title.Parent = top

    local closeButton = Instance.new("TextButton")
    closeButton.Size = UDim2.fromOffset(24, 24)
    closeButton.Position = UDim2.new(1, -30, 0.5, -12)
    closeButton.BackgroundColor3 = Color3.fromRGB(72, 54, 62)
    closeButton.Text = "X"
    closeButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    closeButton.TextSize = 12
    closeButton.Font = Enum.Font.GothamBold
    closeButton.BorderSizePixel = 0
    closeButton.Parent = top

    local closeCorner = Instance.new("UICorner")
    closeCorner.CornerRadius = UDim.new(0, 8)
    closeCorner.Parent = closeButton

    PreviewHolder = Instance.new("Frame")
    PreviewHolder.Size = UDim2.fromOffset(previewSize, previewSize)
    PreviewHolder.Position = UDim2.fromOffset(11, 42)
    PreviewHolder.BackgroundColor3 = Color3.fromRGB(12, 12, 14)
    PreviewHolder.BorderSizePixel = 0
    PreviewHolder.ClipsDescendants = true
    PreviewHolder.Parent = PreviewFrame

    local holderCorner = Instance.new("UICorner")
    holderCorner.CornerRadius = UDim.new(0, 8)
    holderCorner.Parent = PreviewHolder

    local info = Instance.new("TextLabel")
    info.BackgroundTransparency = 1
    info.Size = UDim2.new(1, -12, 0, 14)
    info.Position = UDim2.new(0, 6, 1, 5)
    info.Text = tostring(CurrentQuality) .. "x" .. tostring(CurrentQuality) .. " preview | higher is slower"
    info.TextColor3 = Color3.fromRGB(188, 188, 198)
    info.TextXAlignment = Enum.TextXAlignment.Left
    info.Font = Enum.Font.Gotham
    info.TextSize = 11
    info.Parent = PreviewFrame

    for y = 1, data.h do
        for x = 1, data.w do
            local cell = Instance.new("Frame")
            cell.BorderSizePixel = 0
            cell.Size = UDim2.fromOffset(previewCell, previewCell)
            cell.Position = UDim2.fromOffset((x - 1) * previewCell, (y - 1) * previewCell)
            cell.Parent = PreviewHolder
            PreviewCells[(y - 1) * data.w + x] = cell
        end
    end

    closeButton.MouseButton1Click:Connect(function()
        if PreviewGui then
            PreviewGui.Enabled = false
        end
    end)

    makeDraggable(PreviewFrame, top)
    refreshPreview()
end

local function showPreview()
    createPreviewGui()

    if PreviewGui then
        PreviewGui.Enabled = true
    end
end

local Window = Library:CreateWindow({
    Title = "DataBase Image Loader",
    Subtitle = "IceCream + Gojo + Bunny + KissScene + CreepySmile + Obito + FunnyMonkey",
    Size = UDim2.new(0, 500, 0, 370),
    Theme = "Dark",
    AccentColor = Color3.fromRGB(120, 80, 255),
    ToggleKey = Enum.KeyCode.RightControl,
    KeySystem = false,
})

local Main = Window:CreateTab("Images")

Main:CreateSection("GitHub DataBase")
Main:CreateParagraph({
    Title = "Loaded from your repo",
    Content = "Pick IceCream, Gojo, Bunny, KissScene, CreepySmile, Obito, or FunnyMonkey. Choose quality, preview it, then draw it to the canvas.",
})

Main:CreateDropdown({
    Name = "Image",
    Options = {"IceCream", "Gojo", "Bunny", "KissScene", "CreepySmile", "Obito", "FunnyMonkey"},
    Default = "FunnyMonkey",
    MultiSelect = false,
    Callback = function(value)
        SelectedImage = tostring(value or "Gojo")
        CurrentPack = nil
        destroyPreview()
        loadSelectedPack(true)
    end,
})

Main:CreateDropdown({
    Name = "Quality",
    Options = {"64", "96", "128"},
    Default = "128",
    MultiSelect = false,
    Callback = function(value)
        CurrentQuality = tostring(value or "128")

        if PreviewGui and PreviewGui.Parent then
            showPreview()
        end

        notify("Quality", "Set quality to " .. tostring(CurrentQuality) .. ".", "info", 2)
    end,
})

Main:CreateDropdown({
    Name = "Angle",
    Options = {"0", "90", "180", "270"},
    Default = "0",
    MultiSelect = false,
    Callback = function(value)
        CurrentAngle = tonumber(value) or 0

        if PreviewGui and PreviewGui.Parent then
            refreshPreview()
        end

        notify("Angle", "Set to " .. tostring(CurrentAngle) .. " degrees.", "info", 2)
    end,
})

Main:CreateButton({
    Name = "Reload Selected Data",
    Callback = function()
